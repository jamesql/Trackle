generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DailySong {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  trackId   String
  createdAt DateTime @default(now())
}

model SongPool {
  id       Int     @id @default(autoincrement())
  trackId  String  @unique
  title    String
  artist   String
  genre    String?
  active   Boolean @default(true)
}

model DiscordDailyResult {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  discordId String   // Discord user ID
  guildId   String   // Discord guild (server) ID
  username  String   // Display name for the review
  score     String   // "3/6" or "X/6"
  guessGrid String   // Emoji grid string
  won       Boolean
  attempts  Int      // Number of attempts used
  createdAt DateTime @default(now())

  @@unique([date, discordId, guildId])
}

model DiscordReviewChannel {
  id        Int    @id @default(autoincrement())
  guildId   String @unique
  channelId String
}
